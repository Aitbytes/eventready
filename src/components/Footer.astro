---
interface Props {
  appName: string;
}
const { appName } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="py-12 px-4 bg-surface-elevated border-t border-border">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-text-muted">
      &copy; {year} EventReady. All rights reserved.
    </p>
    <div class="flex items-center gap-6">
      <a href="#" class="text-sm text-text-muted hover:text-primary transition-colors duration-200">Privacy Policy</a>
      <a href="#" class="text-sm text-text-muted hover:text-primary transition-colors duration-200">Terms of Service</a>
    </div>
  </div>
</footer>
