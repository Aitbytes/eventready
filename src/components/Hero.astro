---
import WaitlistForm from './WaitlistForm.astro';

interface Props {
  appName: string;
}
const { appName } = Astro.props;
---

<section class="relative py-20 sm:py-32 px-4 overflow-hidden">
  <!-- Decorative background shapes -->
  <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <!-- Large soft circle top-right -->
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-primary/10 blur-3xl"></div>
    <!-- Medium circle bottom-left -->
    <div class="absolute -bottom-16 -left-16 w-72 h-72 rounded-full bg-accent/10 blur-3xl"></div>
    <!-- Small accent circle -->
    <div class="absolute top-1/3 left-1/4 w-40 h-40 rounded-full bg-primary-light/20 blur-2xl"></div>
  </div>

  <div class="max-w-4xl mx-auto text-center">
    <!-- Eyebrow -->
    <p class="text-sm font-semibold text-primary uppercase tracking-wider mb-6" data-reveal>
      For professionals who dread networking events
    </p>

    <!-- Headline -->
    <h1 class="font-heading text-display font-bold text-text-main mb-6" data-reveal data-reveal-delay="1">
      Dread the networking event. Enjoy the lead-up. Walk in ready.
    </h1>

    <!-- Subheadline -->
    <p class="text-lead text-text-muted max-w-2xl mx-auto mb-10" data-reveal data-reveal-delay="2">
      5 minutes before your next event, EventReady generates personalized conversation openers and runs one AI practice round—so your brain doesn't go blank when someone asks what you do.
    </p>

    <!-- Waitlist form -->
    <div data-reveal data-reveal-delay="3">
      <WaitlistForm
        projectName={appName}
        buttonText="Join the Waitlist"
        incentiveText="Join 2,400+ professionals who've signed up for early access"
        variant="hero"
        formId="hero"
      />
    </div>
  </div>
</section>
