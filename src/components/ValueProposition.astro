---
const valueProps = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>`,
    title: "Finally, event-specific prep",
    description: "No more generic 'social confidence' tips. EventReady asks what kind of event you're walking into—conference, client dinner, networking mixer—and gives you exactly what to say."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-6 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
    title: "Your brain goes blank. We fixed that.",
    description: "One AI roleplay round before you walk in. Practice initiating conversation with zero judgment, so when someone says 'So, what do you do?'—you actually have an answer."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
    title: "Anticipatory anxiety doesn't have to ruin your whole week",
    description: "The dread before the event is often worse than the event itself. EventReady helps you stop catastrophizing so you can actually enjoy the 48 hours leading up to it."
  }
];
---

<section id="value-props" class="py-16 sm:py-24 px-4 bg-surface">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-title font-bold text-primary text-center mb-12 sm:mb-16" data-reveal>
      What EventReady does for you
    </h2>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {valueProps.map((prop, i) => (
        <article
          class="bg-surface-elevated rounded-2xl p-7 shadow-card border border-border/50 hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-300 flex flex-col gap-4"
          data-reveal
          data-reveal-delay={String(Math.min(i + 1, 5))}
        >
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
            <Fragment set:html={prop.icon} />
          </div>
          <div>
            <h3 class="font-heading text-lg font-semibold text-primary mb-2 leading-snug">
              {prop.title}
            </h3>
            <p class="text-text-muted leading-relaxed text-sm sm:text-base">
              {prop.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
